<!--
  app-icon 统一图标组件

  通过 adapter 模式将语义图标名翻译为后端原生组件 props。
  - 命中映射 → 渲染为 TDesign <t-icon> 组件
  - 未命中映射 → 降级为 <text> 纯文本渲染，页面原样展示 name

  用法示例：
    <app-icon name="CLOSE" size="{{32}}" color="$primary" />
    <app-icon name="CHEVRON_DOWN" />
-->
<t-icon wx:if="{{output.componentType === 't-icon'}}"
  name="{{output.props.name}}"
  size="{{output.props.size}}"
  fill-color="{{output.props.fillColor}}"
  stroke-color="{{output.props.strokeColor}}"
  stroke-width="{{output.props.strokeWidth}}"
  brand="{{output.props.brand}}"
/>
<text wx:elif="{{output.componentType === 'text'}}" style="{{output.inlineStyle}}">{{output.props.text}}</text>
