/* ── EmptyState 通用空状态 ──────────────────────────────── */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-lg) 0;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: var(--spacing-md);
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  text-align: center;
}

.empty-action {
  margin-top: var(--spacing-md);
  padding: 16rpx 48rpx;
  background-color: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-btn);
  font-size: 28rpx;
  font-weight: 500;
}
