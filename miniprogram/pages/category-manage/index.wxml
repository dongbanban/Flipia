<view class="page">
  <view wx:if="{{loading}}" class="loading-state">
    <text class="loading-hint">加载中…</text>
  </view>

  <view wx:else class="content">
    <view class="section-title">当前分类</view>

    <view class="tag-grid">
      <block wx:for="{{categories}}" wx:key="id">
        <view class="tag-item">
          <text
            class="tag-name"
            data-id="{{item.id}}"
            bind:tap="onStartRename"
          >{{item.name}}</text>
          <view
            class="remove-badge tag-delete"
            data-id="{{item.id}}"
            catch:tap="onDelete"
          ><app-icon name="CLOSE" size="{{24}}" color="var(--color-primary)" /></view>
        </view>
      </block>

      <view class="tag-item tag-item--add" bind:tap="onStartAdd">
        <app-icon name="ADD" size="{{48}}" color="var(--color-primary)" />
      </view>
    </view>

    <modal
      show="{{editingId !== ''}}"
      title="重命名分类"
      confirmText="完成"
      cancelText="取消"
      bind:confirm="onConfirmRename"
      bind:cancel="onCancelRename"
      bind:close="onCancelRename"
    >
      <input
        class="tag-input {{editError ? 'tag-input--error' : ''}}"
        value="{{editValue}}"
        maxlength="10"
        bind:input="onRenameInput"
        focus
      />
      <text wx:if="{{editError}}" class="tag-error">{{editError}}</text>
    </modal>

    <modal
      show="{{adding}}"
      title="新增分类"
      confirmText="完成"
      cancelText="取消"
      bind:confirm="onConfirmAdd"
      bind:cancel="onCancelAdd"
      bind:close="onCancelAdd"
    >
      <input
        class="tag-input {{addError ? 'tag-input--error' : ''}}"
        value="{{addValue}}"
        placeholder="新分类名"
        maxlength="10"
        bind:input="onAddInput"
        focus
      />
      <text wx:if="{{addError}}" class="tag-error">{{addError}}</text>
    </modal>

    <empty-state wx:if="{{categories.length === 0 && !adding}}" text="暂无分类" actionText="新增分类" bind:action="onStartAdd" />
  </view>
</view>
