.page {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--color-bg);
  overflow-y: auto;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100%;
}

.loading-hint {
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

.content {
  padding: 32rpx;
}

.section-title {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 24rpx;
}

.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  align-items: flex-start;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 16rpx 14rpx 28rpx;
  background-color: #fff;
  border-radius: 48rpx;
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.tag-name {
  max-width: 120rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.tag-delete {
  margin-left: 12rpx;
  flex-shrink: 0;
}

.tag-item--add {
  border: 2rpx dashed #cce0d3;
  background-color: transparent;
  padding: 14rpx 28rpx;
}

.tag-add-icon {
  color: var(--color-primary);
  font-size: 32rpx;
  font-weight: 400;
  line-height: 1;
}

.tag-edit-group {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tag-edit-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 12rpx;
  background-color: var(--color-primary-light);
  border-radius: 48rpx;
}

.tag-input {
  width: 150rpx;
  height: 48rpx;
  font-size: 26rpx;
  color: var(--color-primary);
  background: transparent;
  outline: none;
}

.tag-input--error {
  color: #ff4d4f;
}

.tag-edit-done {
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 600;
  flex-shrink: 0;
}

.tag-edit-cancel {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.tag-error {
  font-size: 24rpx;
  color: #ff4d4f;
  padding-left: 8rpx;
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-hint {
  color: var(--color-text-secondary);
  font-size: 28rpx;
}
