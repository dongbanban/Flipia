<view class="page">
  <!-- Search bar -->
  <view class="search-bar">
    <view class="search-bar__inner">
      <text class="search-bar__icon">🔍</text>
      <input
        class="search-bar__input"
        type="text"
        placeholder="搜索菜品…"
        value="{{searchKeyword}}"
        bind:input="onSearchInput"
      />
      <view
        wx:if="{{searchKeyword}}"
        class="search-bar__clear"
        bind:tap="onClearSearch"
      >✕</view>
    </view>
  </view>

  <!-- 分类 tab 横向滚动 — hidden during search -->
  <view wx:if="{{!searchKeyword}}" class="tab-bar-wrap">
    <scroll-view class="tab-bar" scroll-x enable-flex>
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="tab-item {{index === activeTab ? 'tab-item--active' : ''}}"
        data-idx="{{index}}"
        bind:tap="onTabChange"
      >{{item.name}}</view>
    </scroll-view>
  </view>

  <!-- 加载骨架屏 / 菜品列表 / 空状态 -->
  <view class="dish-area">
    <!-- Search mode: loading skeleton -->
    <view wx:if="{{searchKeyword && loading}}" class="skeleton-list">
      <view wx:for="{{[1,2,3,4,5]}}" wx:key="*this" class="skeleton-card" />
    </view>

    <!-- Search mode: results -->
    <scroll-view wx:elif="{{searchKeyword && searchResults.length > 0}}" scroll-y class="dish-list">
      <view
        wx:for="{{searchResults}}"
        wx:key="_id"
        class="dish-card {{item.enabled ? '' : 'dish-card--disabled'}}"
        data-dish="{{item}}"
        data-idx="{{index}}"
        bind:tap="onOpenEdit"
      >
        <image
          wx:if="{{item.images && item.images.length > 0}}"
          class="dish-thumb"
          src="{{item.images[0]}}"
          mode="aspectFill"
        />
        <view wx:else class="dish-thumb dish-thumb--placeholder" />
        <view class="dish-info">
          <text class="dish-name">{{item.name}}</text>
          <view class="dish-category-badge">{{item.categoryName}}</view>
          <text
            wx:if="{{memberCount > 1 && item.creatorName}}"
            class="dish-creator"
          >大厨：{{item.creatorName}}</text>
        </view>
        <view class="dish-card-actions">
          <view
            class="dish-toggle-text {{item.enabled ? 'dish-toggle-text--on' : 'dish-toggle-text--off'}}"
            data-dish="{{item}}"
            data-idx="{{index}}"
            catchtap="onToggleEnabled"
          >{{item.enabled ? '今日供应' : '今日停供'}}</view>
          <view
            class="dish-delete-btn"
            data-dish="{{item}}"
            catchtap="onCardDeleteDish"
          >下架</view>
        </view>
      </view>
    </scroll-view>

    <!-- Search mode: empty -->
    <empty-state wx:elif="{{searchKeyword && !loading && searchResults.length === 0}}" text="没有找到相关菜品" />

    <!-- Normal mode: loading skeleton -->
    <view wx:elif="{{loading}}" class="skeleton-list">
      <view wx:for="{{[1,2,3,4,5]}}" wx:key="*this" class="skeleton-card" />
    </view>

    <!-- Normal mode: dish list -->
    <scroll-view wx:elif="{{dishes.length > 0}}" scroll-y class="dish-list">
      <view
        wx:for="{{dishes}}"
        wx:key="_id"
        class="dish-card {{item.enabled ? '' : 'dish-card--disabled'}}"
        data-dish="{{item}}"
        data-idx="{{index}}"
        bind:tap="onOpenEdit"
      >
        <image
          wx:if="{{item.images && item.images.length > 0}}"
          class="dish-thumb"
          src="{{item.images[0]}}"
          mode="aspectFill"
        />
        <view wx:else class="dish-thumb dish-thumb--placeholder" />
        <view class="dish-info">
          <text class="dish-name">{{item.name}}</text>
          <text
            wx:if="{{memberCount > 1 && item.creatorName}}"
            class="dish-creator"
          >大厨：{{item.creatorName}}</text>
        </view>
        <view class="dish-card-actions">
          <view
            class="dish-toggle-text {{item.enabled ? 'dish-toggle-text--on' : 'dish-toggle-text--off'}}"
            data-dish="{{item}}"
            data-idx="{{index}}"
            catchtap="onToggleEnabled"
          >{{item.enabled ? '今日供应' : '今日停供'}}</view>
          <view
            class="dish-delete-btn"
            data-dish="{{item}}"
            catchtap="onCardDeleteDish"
          >下架</view>
        </view>
      </view>
    </scroll-view>

    <!-- Normal mode: empty (with categories) -->
    <empty-state
      wx:elif="{{categories.length > 0}}"
      text="还没有菜品，快去添加吧~"
      actionText="添加菜品"
      bind:action="onOpenAdd"
    />

    <!-- Normal mode: empty (no categories) -->
    <empty-state wx:else text="暂无分类" />
  </view>

  <!-- 浮动添加按钮 — hidden during search -->
  <view wx:if="{{categories.length > 0 && !searchKeyword}}" class="fab" bind:tap="onOpenAdd">+</view>

  <!-- 添加/编辑表单弹层 -->
  <modal
    show="{{formVisible}}"
    title="{{formMode === 'add' ? '添加菜品' : '编辑菜品'}}"
    bind:close="onCloseForm"
  >
    <view class="form-content">
      <!-- Tabs (add mode only) -->
      <view wx:if="{{formMode === 'add'}}" class="form-tabs">
        <view
          class="form-tab {{formTab === 'manual' ? 'form-tab--active' : ''}}"
          data-tab="manual"
          bind:tap="onFormTabChange"
        >手动添加</view>
        <view
          class="form-tab {{formTab === 'batch' ? 'form-tab--active' : ''}}"
          data-tab="batch"
          bind:tap="onFormTabChange"
        >批量导入</view>
      </view>

      <!-- Manual tab / Edit mode -->
      <block wx:if="{{formMode === 'edit' || formTab === 'manual'}}">
        <!-- 菜品名 -->
        <view class="form-field">
          <text class="form-label">菜品名</text>
          <input
            class="form-input {{formNameError ? 'form-input--error' : ''}}"
            value="{{formData.name}}"
            placeholder="最多 20 字"
            maxlength="20"
            bind:input="onFormNameInput"
          />
          <text wx:if="{{formNameError}}" class="form-error">{{formNameError}}</text>
        </view>

        <!-- 分类 -->
        <view class="form-field">
          <text class="form-label">分类</text>
          <picker
            mode="selector"
            range="{{formCategoriesForPicker}}"
            range-key="name"
            value="{{formCategoryIdx}}"
            bind:change="onFormCategoryChange"
          >
            <view class="form-picker">{{formCategoriesForPicker[formCategoryIdx].name}}</view>
          </picker>
        </view>

        <!-- 新建分类 (add mode only) -->
        <view wx:if="{{showNewCategory}}" class="form-field form-new-cat">
          <input
            class="form-input {{newCategoryError ? 'form-input--error' : ''}}"
            value="{{newCategoryName}}"
            placeholder="输入分类名称（最多 10 字）"
            maxlength="10"
            bind:input="onNewCategoryNameInput"
            focus="{{showNewCategory}}"
          />
          <text wx:if="{{newCategoryError}}" class="form-error">{{newCategoryError}}</text>
          <view class="form-new-cat-actions">
            <view class="form-new-cat-cancel" bind:tap="onCancelNewCategory">取消</view>
            <view class="form-new-cat-confirm {{creatingCategory ? 'form-new-cat-confirm--loading' : ''}}" bind:tap="onConfirmNewCategory">
              {{creatingCategory ? '创建中…' : '确认'}}
            </view>
          </view>
        </view>

        <!-- 图片上传 -->
        <view class="form-field">
          <text class="form-label">图片</text>
          <view class="image-list">
            <view
              wx:for="{{formData.images}}"
              wx:key="*this"
              class="image-item"
            >
              <image class="image-preview" src="{{item}}" mode="aspectFill" />
              <view class="remove-badge image-remove" data-idx="{{index}}" bind:tap="onRemoveImage">×</view>
            </view>
            <view
              wx:if="{{formData.images.length < 1}}"
              class="image-add {{formUploading ? 'image-add--uploading' : ''}}"
              bind:tap="onChooseImages"
            >
              <text wx:if="{{formUploading}}">上传中…</text>
              <text wx:else>+</text>
            </view>
          </view>
        </view>

        <!-- 烹饪描述 (edit mode only) -->
        <view wx:if="{{formMode === 'edit'}}" class="form-field">
          <text class="form-label">烹饪描述</text>
          <textarea
            class="form-textarea"
            value="{{formData.cookingDescription}}"
            placeholder="烹饪要点、备注…"
            maxlength="200"
            bind:input="onCookingDescriptionInput"
          />
        </view>

        <view class="form-submit {{formDirty ? '' : 'form-submit--disabled'}}" bind:tap="onSaveDish">保存</view>

        <!-- 编辑模式：启用/禁用 + 下架 -->
        <view wx:if="{{formMode === 'edit'}}" class="form-secondary-actions">
          <view
            class="form-toggle-btn {{formData.enabled ? 'form-toggle-btn--on' : 'form-toggle-btn--off'}}"
            bind:tap="onFormToggleEnabled"
          >{{formData.enabled ? '✓ 今日供应' : '○ 今日停供'}}</view>
          <view class="form-delete-btn" bind:tap="onFormDeleteDish">下架菜品</view>
        </view>
      </block>

      <!-- Batch import tab (add mode only) -->
      <block wx:elif="{{formTab === 'batch'}}">
        <!-- 第一步：选择源厨房 -->
        <block wx:if="{{importStep === 'selectGroup'}}">
          <view class="form-field">
            <text class="form-label">选择源厨房</text>
            <picker
              mode="selector"
              range="{{importSourceGroups}}"
              range-key="name"
              value="{{importSourceGroupIdx}}"
              bind:change="onImportSourceGroupChange"
            >
              <view class="form-picker">{{importSourceGroups[importSourceGroupIdx].name}}</view>
            </picker>
          </view>
          <view class="form-submit" bind:tap="onImportNextStep">
            <text wx:if="{{importLoadingCategories}}">加载中…</text>
            <text wx:else>下一步</text>
          </view>
        </block>

        <!-- 第二步：勾选分类 -->
        <block wx:elif="{{importStep === 'selectCategories'}}">
          <view class="form-field">
            <text class="form-label">勾选要导入的分类</text>
          </view>
          <scroll-view scroll-y class="import-category-list">
            <view
              wx:for="{{importSourceCategories}}"
              wx:key="id"
              class="import-cat-item"
              data-idx="{{index}}"
              bind:tap="onImportToggleCategory"
            >
              <view class="import-cat-check {{item.checked ? 'import-cat-check--on' : ''}}">
                <text wx:if="{{item.checked}}">✓</text>
              </view>
              <text class="import-cat-name">{{item.name}}</text>
              <text class="import-cat-count">{{item.dishCount}}道</text>
            </view>
          </scroll-view>
          <view class="import-actions">
            <view class="import-prev-btn" bind:tap="onImportPrevStep">返回选择</view>
            <view class="import-confirm-btn {{importing ? 'import-confirm-btn--loading' : ''}}" bind:tap="onConfirmImport">
              <text wx:if="{{importing}}">导入中…</text>
              <text wx:else>确认导入</text>
            </view>
          </view>
        </block>
      </block>
    </view>
  </modal>
</view>
