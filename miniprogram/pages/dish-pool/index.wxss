.page {
  display: flex;
  flex-direction: column;
  position: absolute;
  top: 88rpx;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--color-bg);
}

/* ── Search bar ── */
.search-bar {
  flex-shrink: 0;
  padding: 16rpx 24rpx;
  background: var(--color-bg);
}

.search-bar__inner {
  display: flex;
  align-items: center;
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 0 20rpx;
}

.search-bar__icon {
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-bar__input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: var(--color-text);
}

.search-bar__clear {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* ── Category badge (search results) ── */
.dish-category-badge {
  display: inline-block;
  align-self: flex-start;
  font-size: 20rpx;
  color: var(--color-primary);
  background: #fff;
  border: 1rpx solid rgba(200, 129, 94, 0.2);
  border-radius: 16rpx;
  padding: 2rpx 14rpx;
  margin-top: 4rpx;
}

/* ── Tab bar ── */
.tab-bar-wrap {
  height: 76rpx;
  background: var(--color-bg);
  border-bottom: 1rpx solid #e8e8e8;
  flex-shrink: 0;
}

.tab-bar {
  display: flex;
  white-space: nowrap;
  height: 100%;
  padding: 0 16rpx;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  height: 100%;
  box-sizing: border-box;
}

.tab-item--active {
  color: var(--color-primary);
  font-weight: 600;
  border-bottom: 4rpx solid var(--color-primary);
}

/* ── Dish list area ── */
.dish-area {
  flex: 1;
  position: relative;
  overflow: hidden;
}

.dish-list {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  padding-top: 24rpx;
}

/* ── Dish card ── */
.dish-card {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.dish-card--disabled .dish-thumb,
.dish-card--disabled .dish-name {
  opacity: 0.4;
}

.dish-card-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.dish-switch-wrap {
  display: flex;
  align-items: center;
}

.dish-thumb {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-card);
  flex-shrink: 0;
  background-color: var(--color-bg-secondary);
}

.dish-thumb--placeholder {
  background-color: var(--color-bg-secondary);
}

.dish-name {
  font-size: 30rpx;
  color: var(--color-text);
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.dish-info {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.dish-creator {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

/* ── Skeleton ── */
.skeleton-list {
  padding: 24rpx;
}

.skeleton-card {
  height: 96rpx;
  border-radius: var(--radius-card);
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s infinite;
  margin-bottom: 24rpx;
}

@keyframes shimmer {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* ── Dish toggle text ── */
.dish-toggle-text {
  font-size: 26rpx;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  border: 1rpx solid;
}

.dish-toggle-text--on {
  color: var(--color-primary);
  border-color: var(--color-primary);
  background-color: #fff;
}

.dish-toggle-text--off {
  color: #999;
  border-color: #d9d9d9;
  background-color: #fff;
}

.dish-delete-btn {
  font-size: 26rpx;
  color: var(--color-primary);
  padding: 8rpx 0 8rpx 8rpx;
}

/* ── Form secondary actions (edit mode) ── */
.form-secondary-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.form-toggle-btn {
  flex: 1;
  height: 80rpx;
  border-radius: var(--radius-card);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.form-toggle-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 80rpx;
}

.form-toggle-label {
  display: flex;
  align-items: center;
}

.form-toggle-btn--on {
  background-color: #fff;
  color: #07c160;
}

.form-toggle-btn--off {
  background-color: #fff;
  color: var(--color-text-secondary);
}

.form-delete-btn {
  flex: 1;
  height: 80rpx;
  border-radius: var(--radius-card);
  background-color: #fff;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}

/* ── FAB ── */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 100rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

/* ── Form content ── */
.form-content {
  display: flex;
  flex-direction: column;
  padding-bottom: 0;
}

.form-field {
  margin-bottom: 28rpx;
}

/* Merged row: dish name + category side by side */
.form-field--row {
  display: flex;
  gap: 20rpx;
}

.form-field-col {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.form-field-col--name {
  flex: 55;
}

.form-field-col--category {
  flex: 45;
}

/* Edit-mode scroll container: keeps bottom buttons always visible */
.form-editor {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.form-editor-scroll {
  flex: 1;
  min-height: 0;
}

.form-editor-actions {
  flex-shrink: 0;
  padding-top: 16rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: var(--radius-card);
  padding: 0 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.form-input--error {
  border-color: #ff4d4f;
}

.form-error {
  display: block;
  font-size: 24rpx;
  color: #ff4d4f;
  margin-top: 8rpx;
}

.form-picker {
  height: 80rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: var(--radius-card);
  padding: 0 20rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  color: var(--color-text);
}

/* ── Form tabs ── */
.form-tabs {
  display: flex;
  gap: 0;
  margin-bottom: 32rpx;
  border-bottom: 2rpx solid #e8e8e8;
}

.form-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  border-bottom: 4rpx solid transparent;
  margin-bottom: -2rpx;
}

.form-tab--active {
  color: var(--color-primary);
  font-weight: 600;
  border-bottom-color: var(--color-primary);
}

/* ── New category inline ── */
.form-new-cat {
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: var(--radius-card);
}

.form-new-cat .form-input {
  margin-bottom: 16rpx;
}

.form-new-cat-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.form-new-cat-cancel {
  flex: 1;
  height: 72rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: var(--radius-card);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.form-new-cat-confirm {
  flex: 1;
  height: 72rpx;
  background-color: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-card);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}

.form-new-cat-confirm--loading {
  opacity: 0.7;
}

/* ── Cooking description textarea ── */
.form-textarea {
  width: 100%;
  min-height: 160rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: var(--radius-card);
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 1.6;
}

/* ── Image upload ── */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.image-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.image-preview {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-card);
}

.image-remove {
  position: absolute;
  top: -16rpx;
  right: -14rpx;
}

.image-add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: var(--radius-card);
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-add--uploading {
  font-size: 24rpx;
}

/* ── Save button ── */
.form-submit {
  margin-top: 16rpx;
  height: 88rpx;
  background-color: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-card);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
}

.form-submit--disabled {
  background-color: #d9d9d9;
  color: rgba(255, 255, 255, 0.8);
}

/* ── Import entry ── */
.import-entry {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  border-left: 1rpx solid #e8e8e8;
}

.import-entry__text {
  font-size: 26rpx;
  color: var(--color-primary);
}

/* ── Import category list ── */
.import-category-list {
  max-height: 480rpx;
  margin-bottom: 24rpx;
}

.import-cat-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.import-cat-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  border: 2rpx solid #d9d9d9;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.import-cat-check--on {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
}

.import-cat-name {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-text);
  margin-left: 20rpx;
}

.import-cat-count {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

/* ── Import actions ── */
.import-actions {
  display: flex;
  gap: 16rpx;
}

.import-prev-btn {
  flex: 1;
  height: 88rpx;
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-card);
  color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}

.import-confirm-btn {
  flex: 2;
  height: 88rpx;
  background-color: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-card);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
}

.import-confirm-btn--loading {
  opacity: 0.7;
}
