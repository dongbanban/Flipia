.page {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--color-bg);
  overflow-y: auto;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100%;
}

.loading-hint {
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

.content {
  padding: 32rpx;
}

.section-title {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 24rpx;
}

.group-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.group-card {
  position: relative;
  width: calc((100% - 32rpx) / 3);
  height: calc((100vw - 96rpx) / 3);
  background-color: var(--color-primary-light);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-card);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 12rpx 16rpx 12rpx;
  box-sizing: border-box;
}

.group-card-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  flex: 1;
  justify-content: center;
}

.group-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  max-width: 100%;
}

.group-name {
  font-size: 26rpx;
  color: var(--color-text);
  font-weight: 600;
  text-align: center;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  word-break: break-all;
  flex: 1;
  min-width: 0;
}

.group-count-badge {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background-color: #fff;
  color: var(--color-primary);
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  flex-shrink: 0;
}

.group-active-badge {
  font-size: 24rpx;
  color: var(--color-primary);
  background-color: #fff;
  padding: 0 14rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  border-radius: 16rpx;
  font-weight: 500;
}

.card-active-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 0 4rpx;
  box-sizing: border-box;
}

.card-cancel-btn {
  height: 44rpx;
  padding: 0 14rpx;
  border-radius: 10rpx;
  background-color: #fff;
  color: var(--color-primary);
  font-size: 24rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 0 2rpx var(--color-primary);
}

.card-set-btn {
  font-size: 24rpx;
  color: var(--color-primary);
  background-color: #fff;
  padding: 0 24rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  border-radius: 20rpx;
  font-weight: 500;
}

.card-remove {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
}

.add-row {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 28rpx;
  background-color: #fff;
  border-radius: var(--radius-card);
  border: 2rpx dashed #cce0d3;
}

.add-row--editing {
  flex-direction: column;
  gap: 12rpx;
  align-items: stretch;
  padding: 24rpx;
  border-style: solid;
  border-color: var(--color-primary-light);
}

.add-icon {
  font-size: 32rpx;
  color: var(--color-primary);
  line-height: 1;
}

.add-label {
  font-size: 28rpx;
  color: var(--color-primary);
}

.card-input {
  width: 100%;
  height: 48rpx;
  font-size: 24rpx;
  color: var(--color-primary);
  background-color: #fff;
  border-radius: 8rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
  text-align: center;
}

.card-input--error {
  color: #ff4d4f;
}

.card-edit-actions {
  display: flex;
  justify-content: center;
  gap: 8rpx;
  width: 100%;
}

.card-action {
  font-size: 22rpx;
  padding: 4rpx 10rpx;
  border-radius: 16rpx;
}

.card-action--primary {
  color: var(--color-primary);
  background-color: var(--color-primary-light);
}

.card-action--muted {
  color: var(--color-text-secondary);
  background-color: #f5f5f5;
}

.card-error {
  font-size: 20rpx;
  color: #ff4d4f;
  text-align: center;
  width: 100%;
}

/* ── Modal content ──────────────────────────────────────── */

.modal-field {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.modal-label {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 500;
  flex-shrink: 0;
}

.modal-input {
  flex: 1;
  height: 56rpx;
  font-size: 28rpx;
  color: var(--color-text);
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 16rpx;
}

.modal-input--error {
  color: #ff4d4f;
}

.modal-error {
  font-size: 24rpx;
  color: #ff4d4f;
  margin-top: 8rpx;
  margin-left: 108rpx;
}

.modal-divider {
  height: 1rpx;
  background-color: #f0f0f0;
  margin: 24rpx 0;
}

.modal-entries {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 16rpx;
}

.modal-entry {
  display: flex;
  align-items: center;
  padding: 16rpx 16rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
}

.modal-entry-name {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text);
}

.stepper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.stepper-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: var(--color-primary-light);
  color: var(--color-primary);
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.stepper-btn--disabled {
  opacity: 0.35;
}

.stepper-value {
  width: 48rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.modal-entry-remove {
  margin-left: 12rpx;
  flex-shrink: 0;
}

.modal-add-entry {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 16rpx;
  border: 2rpx dashed #cce0d3;
  border-radius: 12rpx;
}

.modal-add-icon {
  font-size: 28rpx;
  color: var(--color-primary);
  line-height: 1;
}

.modal-add-text {
  font-size: 26rpx;
  color: var(--color-primary);
}

.modal-footer {
  padding: 24rpx 32rpx 48rpx 32rpx;
}

.modal-btn {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-btn);
  font-size: 30rpx;
  font-weight: 600;
}

.modal-btn--primary {
  background-color: var(--color-primary);
  color: #fff;
}

.modal-btn--muted {
  background-color: #f5f5f5;
  color: var(--color-text-secondary);
}
