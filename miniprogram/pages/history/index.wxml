<group-switcher
  groups="{{groups}}"
  active-group-id="{{activeGroupId}}"
  openid="{{openid}}"
  bind:change="onGroupChange"
  bind:create="onGroupCreate"
/>
<view class="page">
  <view wx:if="{{loading}}" class="loading-state">
    <text class="loading-hint">加载中…</text>
  </view>

  <empty-state wx:elif="{{empty}}" text="暂无记录">
    <text class="empty-sub">抽取确认后记录将出现在这里</text>
  </empty-state>

  <view wx:else class="list">
    <view wx:for="{{dayGroups}}" wx:key="date" class="day-group">
      <view class="day-header">{{item.label}}</view>

      <!-- Swipe-to-delete wrapper for each record card -->
      <view
        wx:for="{{item.records}}"
        wx:key="_id"
        wx:for-item="record"
        class="swipe-wrapper"
        data-record-id="{{record._id}}"
        bindtouchstart="onSwipeStart"
        bindtouchmove="onSwipeMove"
        bindtouchend="onSwipeEnd"
      >
        <!-- Delete button revealed behind card on swipe -->
        <view
          class="swipe-delete"
          style="visibility: {{swipedRecordId === record._id ? 'visible' : 'hidden'}};"
          catchtap="onDeleteRecord"
          data-record-id="{{record._id}}"
        >
          <text>删除</text>
        </view>

        <!-- Card content (translates horizontally on swipe) -->
        <view
          class="swipe-content"
          style="transform: translateX({{_swipeActiveId === record._id ? translateXPx : (swipedRecordId === record._id ? -deleteBtnPx : 0)}}px); transition: {{_swipeActiveId === record._id ? 'none' : 'transform 0.25s ease-out'}};"
        >
          <!-- Horizontal body: image/placeholder left, info right -->
          <view class="card-body">
            <!-- Mode 1: has image -->
            <view
              wx:if="{{record.images && record.images.length > 0}}"
              class="card-image-wrap"
            >
              <image
                class="card-image"
                src="{{record.images[0]}}"
                mode="aspectFill"
                data-images="{{record.images}}"
                data-current="{{record.images[0]}}"
                bind:tap="onPreviewRecordImage"
              />
            </view>
            <!-- Mode 2: no image, upload placeholder -->
            <view
              wx:else
              class="card-placeholder"
              data-record-id="{{record._id}}"
              bindtap="onRecordUploadImage"
            >
              <block wx:if="{{uploadingRecordId === record._id}}">
                <text class="card-placeholder-uploading">上传中…</text>
              </block>
              <block wx:else>
                <text class="card-placeholder-icon">+</text>
                <text class="card-placeholder-text">Flipia时刻</text>
              </block>
            </view>

            <!-- Right info area -->
            <view class="card-info">
              <view class="record-head">
                <text class="record-time">{{record.time}}</text>
                <text wx:if="{{memberCount > 1 && record.drawerLabel}}" class="record-drawer">{{record.drawerLabel}}</text>
              </view>
              <view wx:for="{{record.results}}" wx:key="categoryId" wx:for-item="group" class="record-group">
                <text class="record-category">{{group.categoryName}}：</text>
                <block wx:for="{{group.dishes}}" wx:key="dishId" wx:for-item="dish">
                  <text class="record-dish">{{dish.dishName}}</text>
                </block>
              </view>
            </view>
          </view>

          <!-- Bottom action buttons: share to chat + save as image -->
          <view class="record-actions">
            <button
              class="record-action-btn"
              open-type="share"
              data-record-id="{{record._id}}"
              hover-class="record-action-btn--hover"
            >
              <text class="record-action-icon">↗</text>
              <text>分享给朋友</text>
            </button>
            <view
              class="record-action-btn"
              hover-class="record-action-btn--hover"
              data-record-id="{{record._id}}"
              bindtap="onGenerateShareImage"
            >
              <text class="record-action-icon">↓</text>
              <text>保存为图片</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- Hidden canvas for share image generation (outside .page to avoid clipping) -->
<canvas type="2d" id="shareCanvas" class="share-canvas"></canvas>
