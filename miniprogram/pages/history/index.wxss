.page {
  position: absolute;
  top: 88rpx;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--color-bg-secondary);
  overflow-y: auto;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100%;
}

.loading-hint {
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100%;
  gap: 16rpx;
}

.empty-hint {
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

.empty-sub {
  color: var(--color-text-secondary);
  font-size: 24rpx;
  opacity: 0.6;
}

.list {
  padding: 16rpx 24rpx;
}

.day-group {
  margin-bottom: 24rpx;
}

.day-header {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 10rpx;
  padding-left: 4rpx;
}

/* ── Swipe-to-delete ──────────────────────────── */

.swipe-wrapper {
  position: relative;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.swipe-delete {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 150rpx;
  background-color: #e74c3c;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  border-radius: 0 var(--radius-card) var(--radius-card) 0;
  visibility: hidden;
}

.swipe-content {
  position: relative;
  width: 100%;
  box-sizing: border-box;
  background-color: var(--color-bg);
  border-radius: var(--radius-card);
  padding: 20rpx 20rpx 0 20rpx;
  z-index: 1;
}

/* ── Card internals ───────────────────────────── */

.record-head {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.record-time {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.record-drawer {
  font-size: 20rpx;
  color: var(--color-primary);
  background-color: var(--color-primary-light);
  border-radius: 24rpx;
  padding: 2rpx 12rpx;
  margin-left: 10rpx;
}

.record-group {
  margin-top: 4rpx;
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.6;
}

.record-category {
  font-weight: 600;
}

.record-dish {
  margin-right: 12rpx;
}

.record-photos {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.record-photo-item {
  position: relative;
  width: 140rpx;
  height: 140rpx;
}

.record-photo-thumb {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-card);
}

.record-photo-add {
  width: 140rpx;
  height: 140rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: var(--radius-card);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #bbb;
}

.record-photo-add--uploading {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* ── Bottom action buttons (share + save image) ─ */

.record-actions {
  display: flex;
  margin-top: 12rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.record-action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 16rpx 0;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  background: none;
  border: none;
  line-height: 1;
}

.record-action-btn::after {
  border: none;
}

.record-action-btn--hover {
  opacity: 0.5;
}

.record-action-icon {
  font-size: 24rpx;
}

/* ── Hidden share image canvas ────────────────── */

.share-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 750rpx;
}
