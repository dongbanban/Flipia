.page {
  position: absolute;
  top: 88rpx;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--color-bg-secondary);
  overflow-y: auto;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100%;
}

.loading-hint {
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

.empty-sub {
  color: var(--color-text-secondary);
  font-size: 24rpx;
  opacity: 0.6;
}

.list {
  padding: 16rpx 24rpx;
}

.day-group {
  margin-bottom: 24rpx;
}

.day-header {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 10rpx;
  padding-left: 4rpx;
}

/* ── Swipe-to-delete ──────────────────────────── */

.swipe-wrapper {
  position: relative;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.swipe-delete {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 150rpx;
  background-color: #e74c3c;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  border-radius: 0 var(--radius-card) var(--radius-card) 0;
  visibility: hidden;
}

.swipe-content {
  position: relative;
  width: 100%;
  box-sizing: border-box;
  background-color: var(--color-bg);
  border-radius: var(--radius-card);
  padding: 20rpx;
  z-index: 1;
}

/* ── Card internals ───────────────────────────── */

.record-head {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.record-time {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.record-drawer {
  font-size: 20rpx;
  color: var(--color-primary);
  background-color: #fff;
  border-radius: 24rpx;
  padding: 2rpx 12rpx;
  margin-left: 10rpx;
}

.record-group {
  margin-top: 4rpx;
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.6;
}

.record-category {
  font-weight: 600;
}

.record-dish {
  margin-right: 12rpx;
}

/* ── Card body: horizontal image + info layout ── */

.card-body {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

/* Left image (Mode 1: has image) */

.card-image-wrap {
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
  border-radius: var(--radius-card);
  overflow: hidden;
}

.card-image {
  width: 100%;
  height: 100%;
}

/* Left placeholder (Mode 2: no image) */

.card-placeholder {
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
  border: 2rpx dashed #d9d9d9;
  border-radius: var(--radius-card);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.card-placeholder-icon {
  font-size: 36rpx;
  color: var(--color-primary);
  line-height: 1;
}

.card-placeholder-text {
  font-size: 18rpx;
  color: var(--color-primary);
  line-height: 1.2;
}

.card-placeholder-uploading {
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

/* Right info area */

.card-info {
  flex: 1;
  min-width: 0;
}

/* ── Share icon (top-right corner of card) ───── */

.record-share-icon {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-secondary);
  opacity: 0.55;
  z-index: 2;
  transition: opacity 0.15s ease;
}

.record-share-icon:active {
  opacity: 0.25;
  transform: scale(0.9);
}

.record-share-icon-img {
  width: 32rpx;
  height: 32rpx;
}

/* ── Hidden share image canvas ────────────────── */

.share-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 750rpx;
}


