<group-switcher
  groups="{{groups}}"
  active-group-id="{{activeGroupId}}"
  openid="{{openid}}"
  bind:change="onGroupChange"
  bind:create="onGroupCreate"
/>
<view class="page">
  <view wx:if="{{phase === 'idle' || phase === ''}}" class="idle-area">
    <loading-card loading="{{loadingConfig}}" />
    <block wx:if="{{!loadingConfig}}">
      <view wx:if="{{activeConfigName}}" class="config-switcher" bind:tap="onSwitchConfig">
        <text class="config-label">今天用「</text>
        <text class="config-name">{{activeConfigName}}</text>
        <text class="config-label">」</text>
        <app-icon wx:if="{{configGroupNames.length > 1}}" name="CHEVRON_RIGHT" size="{{26}}" color="$primary" />
      </view>
      <button
        class="draw-btn {{validationError ? 'draw-btn--disabled' : ''}}"
        disabled="{{!!validationError}}"
        bind:tap="onStartDraw"
      >今天吃什么？</button>
      <text wx:if="{{validationError}}" class="validation-error">{{validationError}}</text>
    </block>
  </view>

  <view wx:elif="{{phase === 'drawing'}}" class="drawing-area">
    <view class="auto-flip-bar">
      <button
        class="auto-flip-btn {{(autoFlipping || flippedCount === drawCards.length) ? 'auto-flip-btn--disabled' : ''}}"
        disabled="{{autoFlipping || flippedCount === drawCards.length}}"
        bind:tap="onAutoFlip"
      >翻开看看</button>
    </view>
    <view class="cards-grid">
      <view
        wx:for="{{drawCards}}"
        wx:key="id"
        data-idx="{{index}}"
        class="card-wrapper"
        bind:tap="onFlipCard"
      >
        <flip-card
          flipped="{{item.flipped}}"
          redrawing="{{item.redrawing}}"
          width="300rpx"
          height="400rpx"
        >
          <view slot="back" class="card-back-content">
            <app-icon name="HELP" size="{{64}}" color="$white" />
            <text class="card-back-label">{{item.categoryName}}</text>
          </view>
          <view slot="front" class="card-front-content">
            <image
              wx:if="{{item.imageUrl}}"
              class="card-image"
              src="{{item.imageUrl}}"
              mode="aspectFill"
            />
            <view class="card-name-wrap">
              <text class="card-name">{{item.dishName}}</text>
            </view>
            <view
              wx:if="{{item.flipped && !item.redrawing}}"
              class="redraw-btn"
              data-idx="{{index}}"
              catch:tap="onRedrawCard"
            >
              <text class="redraw-text">换一个</text>
            </view>
          </view>
        </flip-card>
      </view>
    </view>

    <view class="drawing-actions">
      <text class="back-btn" bind:tap="onBackToIdle">不抽了</text>
      <view class="drawing-actions-right">
        <button class="redraw-all-btn {{flippedCount > 0 ? '' : 'redraw-all-btn--disabled'}}" disabled="{{flippedCount === 0}}" bind:tap="onStartDraw">再来一次</button>
        <button
          class="confirm-btn {{flippedCount === drawCards.length ? '' : 'confirm-btn--disabled'}}"
          disabled="{{flippedCount < drawCards.length}}"
          bind:tap="onConfirmDraw"
        >就它了</button>
      </view>
    </view>
  </view>

  <view wx:if="{{!todaySummary && (phase === 'idle' || phase === '') && !loadingConfig}}" class="guide-placeholder">
    <text class="guide-text">吃什么呢？交给 Flipia 吧～</text>
  </view>

  <view wx:if="{{todaySummary}}" class="summary-bar" bind:tap="onGoHistory">
    <text class="summary-text">{{todaySummary}}</text>
    <app-icon name="CHEVRON_RIGHT" size="{{28}}" color="$primary" />
  </view>
</view>
