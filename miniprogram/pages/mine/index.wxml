<group-switcher
  groups="{{groups}}"
  active-group-id="{{activeGroupId}}"
  openid="{{openid}}"
  bind:change="onGroupChange"
  bind:create="onGroupCreate"
/>
<view class="page">
  <view class="profile-card">
    <image
      wx:if="{{avatarUrl}}"
      class="profile-avatar"
      src="{{avatarUrl}}"
      mode="aspectFill"
      binderror="onAvatarError"
    />
    <view wx:else class="profile-avatar profile-avatar--placeholder">
      <text class="profile-avatar__icon">👤</text>
    </view>
    <text class="profile-nickname">{{nickName}}</text>
  </view>

  <view class="menu-list">
    <view class="menu-item" bind:tap="onTapCategoryManage">
      <text class="menu-label">分类配置</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bind:tap="onTapDrawConfig">
      <text class="menu-label">抽取方案</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bind:tap="onTapGroupManage">
      <view class="menu-item-left">
        <text class="menu-label">厨房管理</text>
        <text class="menu-sub" wx:if="{{activeGroupName}}">{{activeGroupName}}</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
