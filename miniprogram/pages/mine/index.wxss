.page {
  position: absolute;
  top: 88rpx;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--color-bg);
  padding: 24rpx;
  overflow-y: auto;
}

.profile-card {
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
  background-color: var(--color-primary-light);
  border-radius: var(--radius-card);
}

.profile-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: var(--color-bg);
  flex-shrink: 0;
}

.profile-avatar--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-avatar__icon {
  font-size: 44rpx;
}

.profile-nickname {
  margin-left: 28rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text);
}

.menu-list {
  border-radius: var(--radius-card);
  overflow: hidden;
  background-color: #fff;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-left {
  display: flex;
  flex-direction: column;
}

.menu-label {
  font-size: 30rpx;
  color: var(--color-text);
}

.menu-sub {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}
