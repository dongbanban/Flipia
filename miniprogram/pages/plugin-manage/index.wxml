<view class="page">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-state">
    <text class="loading-hint">加载中…</text>
  </view>

  <!-- 加载出错 -->
  <view wx:elif="{{error}}" class="error-state">
    <empty-state text="{{error}}" actionText="重试" bind:action="_fetchPlugins" />
  </view>

  <!-- 正常内容 -->
  <view wx:else class="content">
    <!-- 空列表 -->
    <empty-state wx:if="{{plugins.length === 0}}" text="暂无可用插件" />

    <!-- 插件卡片列表 -->
    <view wx:else class="plugin-list">
      <view
        wx:for="{{plugins}}"
        wx:key="id"
        class="plugin-card {{item.unlocked ? 'plugin-card--unlocked' : ''}}"
      >
        <!-- 插件基本信息 -->
        <view class="plugin-header">
          <view class="plugin-info">
            <text class="plugin-name">{{item.name}}</text>
            <text class="plugin-desc">{{item.description}}</text>
          </view>

          <!-- 已解锁：绿色标记 -->
          <view wx:if="{{item.unlocked}}" class="unlocked-badge">
            <text class="unlocked-badge-text">已解锁</text>
          </view>
        </view>

        <!-- 未解锁：进度提示 + 解锁按钮 -->
        <view wx:if="{{!item.unlocked}}" class="plugin-locked">
          <view class="progress-bar">
            <view class="progress-fill" style="width: {{item.target > 0 ? item.current / item.target * 100 : 0}}%"></view>
          </view>
          <view class="locked-footer">
            <text class="progress-hint">{{item.progressHint}}</text>
            <text class="progress-num">{{item.current}}/{{item.target}}</text>
            <button
              class="unlock-btn"
              data-id="{{item.id}}"
              bind:tap="onUnlock"
            >解锁</button>
          </view>
        </view>

        <!-- 已解锁：启用/禁用开关 -->
        <view wx:if="{{item.unlocked}}" class="plugin-toggle">
          <text class="toggle-label">{{item.enabled ? '已启用' : '已禁用'}}</text>
          <switch
            checked="{{item.enabled}}"
            disabled="{{item.toggling}}"
            color="#c8815e"
            data-id="{{item.id}}"
            bindchange="onToggle"
          />
        </view>
      </view>
    </view>
  </view>
</view>
