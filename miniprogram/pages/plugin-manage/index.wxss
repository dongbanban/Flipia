/* ── 页面容器 ────────────────────────────────────────────── */

.page {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--color-bg);
  overflow-y: auto;
}


/* ── 错误态 ──────────────────────────────────────────────── */

.error-state {
  padding-top: 120rpx;
}

/* ── 内容区 ──────────────────────────────────────────────── */

.content {
  padding: 24rpx;
}

/* ── 插件列表 ────────────────────────────────────────────── */

.plugin-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ── 插件卡片 ────────────────────────────────────────────── */

.plugin-card {
  background-color: var(--color-primary-light);
  border-radius: var(--radius-card);
  padding: 28rpx;
  border: 1rpx solid #eed9cb;
}

.plugin-card--unlocked {
  border-color: var(--color-primary);
  background-color: var(--color-primary-light);
}

/* ── 卡片头部 ────────────────────────────────────────────── */

.plugin-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.plugin-info {
  flex: 1;
  min-width: 0;
}

.plugin-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
}

.plugin-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 6rpx;
  display: block;
  line-height: 1.5;
}

/* ── 已解锁标记 ──────────────────────────────────────────── */

.unlocked-badge {
  flex-shrink: 0;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background-color: #e8f5e9;
}

.unlocked-badge-text {
  font-size: 22rpx;
  color: #4caf50;
  font-weight: 500;
}

/* ── 未解锁：环形进度 + 解锁按钮 ──────────────────────────── */

.plugin-locked {
  margin-top: 24rpx;
}

.locked-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

/* 环形进度指示器 */
.progress-ring {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: conic-gradient(
    var(--color-primary) calc(var(--p) * 1turn),
    #e8e8e8 calc(var(--p) * 1turn)
  );
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.progress-ring-inner {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.progress-ring-text {
  font-size: 20rpx;
  color: var(--color-text);
  font-weight: 600;
}

/* 右侧信息列 */
.locked-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.progress-hint {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.4;
}

.unlock-btn {
  align-self: flex-end;
  width: 120rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 500;
  color: #fff;
  background-color: var(--color-primary);
  border-radius: var(--radius-btn);
  padding: 0;
  margin: 0;
  border: none;
}

.unlock-btn::after {
  border: none;
}

/* ── 已解锁：开关行 ──────────────────────────────────────── */

.plugin-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #ecd9c8;
}

.toggle-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}
