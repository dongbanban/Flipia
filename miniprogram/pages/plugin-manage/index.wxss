/* ── 页面容器 ────────────────────────────────────────────── */

.page {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--color-bg);
  overflow-y: auto;
}

/* ── 错误态 ──────────────────────────────────────────────── */

.error-state {
  padding-top: 120rpx;
}

/* ── 内容区 ──────────────────────────────────────────────── */

.content {
  padding: 24rpx;
}

/* ── 2 列网格 ────────────────────────────────────────────── */

.plugin-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.plugin-grid-item {
  /* 高度由 flip-card 的 height 属性控制 */
}

/* ═══════════════════════════════════════════════════════════
   背面（锁定状态）— 渐变背景上的内容
   ═══════════════════════════════════════════════════════════ */

.back-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  padding: 24rpx 20rpx;
  box-sizing: border-box;
  gap: 16rpx;
}

.back-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
  line-height: 1.3;
  /* 最多两行 */
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* ── 环形进度指示器 ──────────────────────────────────────── */

.back-ring {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: conic-gradient(
    var(--color-primary) calc(var(--p) * 1turn),
    rgba(255, 255, 255, 0.25) calc(var(--p) * 1turn)
  );
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.back-ring-inner {
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-ring-pct {
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
}

/* ── 描述文字 ────────────────────────────────────────────── */

.back-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
  line-height: 1.4;
  /* 最多两行 */
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* ── 解锁按钮 ────────────────────────────────────────────── */

.unlock-btn {
  width: 140rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-primary);
  background-color: #fff;
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-btn);
  padding: 0;
  margin: 0;
}

.unlock-btn::after {
  border: none;
}

.unlock-btn--disabled {
  background-color: rgba(255, 255, 255, 0.3);
  color: rgba(255, 255, 255, 0.5);
}

/* ═══════════════════════════════════════════════════════════
   正面（已解锁状态）— 浅色背景上的内容
   ═══════════════════════════════════════════════════════════ */

.front-content {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100%;
  padding: 24rpx 20rpx;
  box-sizing: border-box;
}

.front-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  text-align: center;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.front-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.5;
  margin-top: 12rpx;
  flex: 1;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

/* ── 开关行 ──────────────────────────────────────────────── */

.front-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #e8d5c5;
}

.front-toggle-label {
  font-size: 24rpx;
  color: var(--color-primary);
}
