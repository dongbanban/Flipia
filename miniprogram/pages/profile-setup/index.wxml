<view class="page">
  <view class="content">
    <!-- Intro text -->
    <text class="intro">创建你的账号，快点加入 Flipia 吧</text>

    <!-- Avatar display area (tap for camera/gallery custom upload) -->
    <view class="avatar-display" bindtap="onTapAvatarDisplay">
      <image
        wx:if="{{avatarUrl}}"
        class="avatar-img"
        src="{{avatarUrl}}"
        mode="aspectFill"
      />
      <text wx:else class="avatar-placeholder">👤</text>
      <view class="avatar-ring-inner"></view>
    </view>

    <!-- Nickname input -->
    <view class="nickname-field">
      <input
        class="nickname-input"
        type="nickname"
        value="{{nickName}}"
        placeholder="请输入昵称"
        placeholder-class="nickname-placeholder"
        maxlength="20"
        focus="{{nicknameFocus}}"
        bindinput="onNickInput"
        bindblur="onNicknameBlur"
      />
    </view>

    <!-- Action buttons -->
    <view class="btn-row">
      <button
        class="btn btn--wechat"
        open-type="chooseAvatar"
        bindchooseavatar="onChooseAvatar"
      >使用微信信息</button>
      <button class="btn btn--confirm" bindtap="onConfirm" disabled="{{!canConfirm}}">创建</button>
    </view>
  </view>
</view>
