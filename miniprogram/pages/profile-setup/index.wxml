<view class="page">
  <view class="content">
    <!-- 引导文案 -->
    <text class="intro">先认识一下你吧～</text>

    <!-- 头像展示区（点击使用相机/相册自定义上传） -->
    <view class="avatar-display" bindtap="onTapAvatarDisplay">
      <image
        wx:if="{{avatarUrl}}"
        class="avatar-img"
        src="{{avatarUrl}}"
        mode="aspectFill"
      />
      <app-icon wx:else name="AVATAR" size="{{80}}" color="$text-muted" />
      <view class="avatar-ring-inner"></view>
    </view>

    <!-- 昵称输入 -->
    <view class="nickname-field">
      <input
        class="nickname-input"
        type="nickname"
        value="{{nickName}}"
        placeholder="怎么称呼你"
        placeholder-class="nickname-placeholder"
        maxlength="20"
        focus="{{nicknameFocus}}"
        bindinput="onNickInput"
        bindblur="onNicknameBlur"
      />
    </view>

    <!-- 操作按钮 -->
    <view class="btn-row">
      <button
        class="btn btn--wechat"
        open-type="chooseAvatar"
        bindchooseavatar="onChooseAvatar"
      >用微信信息就行</button>
      <button class="btn btn--confirm" bindtap="onConfirm" disabled="{{!canConfirm}}">就这样</button>
    </view>
  </view>
</view>
