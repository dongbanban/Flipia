.remove-badge {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #fff;
  color: var(--color-primary);
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 0 0 2rpx var(--color-primary),
    0 1rpx 4rpx rgba(0, 0, 0, 0.1);
  line-height: 1;
}
